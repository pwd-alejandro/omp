# One Million Pieces — environment variables.
# Copy to .env for local dev; set the same keys in Cloudflare Pages + GitHub Actions.
# No secrets required to read a public Substack RSS feed.

# Substack RSS feed (source of content — used by ingestion).
SUBSTACK_FEED_URL="https://onemillionpieces.substack.com/feed"

# Where subscribe/read CTAs point (swap for read.onemillionpieces.com if the
# Substack custom domain is purchased later).
SUBSTACK_SUBSCRIBE_URL="https://onemillionpieces.substack.com/subscribe"

# Canonical site URL (used for sitemap, RSS-out, and OG/canonical tags).
PUBLIC_SITE_URL="https://onemillionpieces.com"
